NODE_ENV=development
PORT=3011
API_PREFIX=/api/v1
TZ=Africa/Cairo

# Used to build absolute imageUrls if proxy headers aren't present
PUBLIC_BASE_URL=http://localhost:3011

DB_HOST=localhost
DB_PORT=3306
DB_NAME=instamicro_db
DB_USER=instamicro_user
DB_PASSWORD=changeme

ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3004,https://prosto.instamicrotech.com,https://www.prosto.instamicrotech.com

# Monthly retention: delete invoices whose issue_date is older than N days.
INVOICE_RETENTION_DAYS=30
# 03:15 on the 1st of every month (server time)
INVOICE_RETENTION_CRON=15 3 1 * *

LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
